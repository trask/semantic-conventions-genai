# renovate: datasource=github-releases depName=open-telemetry/weaver versioning=semver-coerced
WEAVER_VERSION=v0.23.0

# renovate: datasource=github-tags depName=open-telemetry/semantic-conventions versioning=semver-coerced
SEMCONV_VERSION=v1.41.0

# Weaver panics in `registry check` when fetching a remote policy pack pinned by
# commit SHA (reproduced on 0.23.0), so POLICY_REPO_REF tracks a named ref
# (branch/tag) rather than a digest. Switch back to a SHA pin once that is
# fixed upstream.
# renovate: datasource=git-refs depName=open-telemetry/opentelemetry-weaver-packages versioning=git
POLICY_REPO_URL=https://github.com/open-telemetry/opentelemetry-weaver-packages.git
POLICY_REPO_REF=main
